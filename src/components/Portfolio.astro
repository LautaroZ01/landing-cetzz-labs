---
import { ChevronLeft, ChevronRight, ArrowRight } from "@lucide/astro";

type Project = {
    title: string;
    description: string;
    image: string;
    link: string;
};

const projects: Project[] = [
    {
        title: "RestoBar",
        description:
            "Landing page para un restobar con un diseño moderno y responsive.",
        image: "/projects/RestoBar.webp",
        link: "https://resto-astro-landing-page.vercel.app/",
    },
    {
        title: "Soluciones de Transporte",
        description:
            "Landing page para cotizar servicios de transporte para personas, materiales y carga.",
        image: "/projects/transporte.webp",
        link: "https://lta-landing-page-transporte-salta.netlify.app/",
    },
    {
        title: "Todo Tela",
        description:
            "Landing page para una tienda de telas con un diseño moderno y responsive.",
        image: "/projects/todo-tela.webp",
        link: "https://www.tododetsalta.com.ar/",
    },
    {
        title: "AniTrendy",
        description:
            "Tienda online de moda con catálogo dinámico y diseño orientado a conversión.",
        image: "/projects/anitrendy.png",
        link: "https://anitrendy.com.ar/",
    },
    {
        title: "Impacto Creativo",
        description:
            "Landing page moderna y vibrante para una agencia de marketing digital.",
        image: "/projects/impactocreativo.png",
        link: "https://impacto-creativo.vercel.app/",
    },
    {
        title: "El Sabor Auténtico",
        description:
            "Landing page donde cada plato cuenta una historia y cada momento es único.",
        image: "/projects/sabor-autentico.webp",
        link: "https://resto-react-landing-page.vercel.app/",
    },
];
---

<section
    id="portafolio"
    class="py-24 lg:py-32 bg-black-50 relative overflow-hidden"
>
    <div class="rocket-bg top-[-5%] right-[-5%] opacity-30 mix-blend-multiply">
    </div>
    <div
        class="absolute left-[-10%] w-[600px] h-[600px] bg-primary-100/90 rounded-full blur-[150px] pointer-events-none z-0"
    >
    </div>

    <div class="max-w-[90rem] mx-auto px-4 sm:px-6 w-full relative z-10">
        <div class="mb-4 md:mb-8">
            <div class="text-center lg:text-left mb-10 lg:mb-0 w-full lg:w-1/2">
                <span
                    class="text-primary-500 font-bold tracking-widest uppercase text-sm mb-4 block"
                    >Nuestro Trabajo</span
                >
                <h3
                    id="portfolio-title"
                    class="text-3xl md:text-5xl lg:text-5xl font-extrabold text-black-900 mb-4 tracking-tight drop-shadow-sm"
                >
                    {projects[0].title}
                </h3>
                <p
                    id="portfolio-desc"
                    class="text-lg md:text-xl text-black-600 leading-relaxed font-normal max-w-4xl min-h-[60px] md:min-h-[84px]"
                >
                    {projects[0].description}
                </p>
            </div>
        </div>

        <div
            class="relative w-full h-[300px] sm:h-[350px] md:h-[450px] lg:h-[580px] flex items-center justify-center perspective-[1500px]"
        >
            <div
                class="absolute -top-5 right-0 md:right-4 z-40 flex items-center gap-3"
            >
                <button
                    id="btn-prev"
                    class="w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-xl bg-white border border-black-100 hover:bg-primary-50 hover:border-primary-300 text-black-600 hover:text-primary-600 transition-all active:scale-95 shadow-soft cursor-pointer"
                    aria-label="Proyecto anterior"
                >
                    <ChevronLeft
                        class="w-5 h-5 md:w-6 md:h-6 pointer-events-none"
                    />
                </button>
                <button
                    id="btn-next"
                    class="w-10 h-10 md:w-12 md:h-12 flex items-center justify-center rounded-xl bg-white border border-black-100 hover:bg-primary-50 hover:border-primary-300 text-black-600 hover:text-primary-600 transition-all active:scale-95 shadow-soft cursor-pointer"
                    aria-label="Siguiente proyecto"
                >
                    <ChevronRight
                        class="w-5 h-5 md:w-6 md:h-6 pointer-events-none"
                    />
                </button>
            </div>
            {
                projects.map((project, index) => (
                    <div
                        class="carousel-item absolute top-0 w-full max-w-[95%] md:max-w-[85%] lg:max-w-[80%] h-full rounded-[2rem] overflow-hidden border border-black-100 shadow-soft-hover transition-all duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] cursor-pointer bg-white"
                        data-index={index}
                    >
                        <img
                            src={project.image}
                            alt={project.title}
                            class="w-full h-full object-cover object-top"
                        />

                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-90 pointer-events-none transition-opacity duration-500" />

                        <a
                            href={project.link}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="carousel-btn absolute bottom-6 right-6 md:bottom-8 md:right-8 inline-flex items-center justify-center gap-2 px-5 md:px-6 py-2 hover:bg-primary-600 bg-white/20 border border-white/30 text-white font-bold text-sm md:text-base rounded-full transition-all active:scale-95 backdrop-blur-md opacity-0 pointer-events-none translate-y-4"
                        >
                            Ver página
                            <ArrowRight class="w-4 h-4 md:w-5 md:h-5 pointer-events-none" />
                        </a>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<script is:inline define:vars={{ projects }}>
    window.portfolioProjects = projects;
</script>

<script>
    import { gsap } from "gsap";

    document.addEventListener("DOMContentLoaded", () => {
        const projects = (window as any).portfolioProjects;
        if (!projects || !projects.length) return;

        let currentIndex = 0;
        const total = projects.length;

        const items = document.querySelectorAll(".carousel-item");

        const titleEl = document.getElementById("portfolio-title");
        const descEl = document.getElementById("portfolio-desc");

        const btnPrev = document.getElementById("btn-prev");
        const btnNext = document.getElementById("btn-next");

        let isAnimating = false;

        const updateCarousel = () => {
            if (titleEl && descEl) {
                gsap.to([titleEl, descEl], {
                    opacity: 0,
                    y: 10,
                    duration: 0.2,
                    stagger: 0.05,
                    ease: "power1.in",
                    onComplete: () => {
                        titleEl.textContent = projects[currentIndex].title;
                        descEl.textContent = projects[currentIndex].description;

                        gsap.to([titleEl, descEl], {
                            opacity: 1,
                            y: 0,
                            duration: 0.4,
                            stagger: 0.05,
                            ease: "power2.out",
                        });
                    },
                });
            }

            const isMobile = window.innerWidth < 768;
            const shiftAmount = isMobile ? "15%" : "25%";
            const scaleAmount = isMobile ? 0.9 : 0.85;

            items.forEach((item, index) => {
                const el = item as HTMLElement;
                const btn = el.querySelector(".carousel-btn") as HTMLElement;

                if (index === currentIndex) {
                    el.style.transform = `translateX(0) scale(1) translateZ(0)`;
                    el.style.opacity = `1`;
                    el.style.zIndex = `30`;
                    el.style.filter = `blur(0px) brightness(1)`;
                    el.style.pointerEvents = "auto";

                    if (btn) {
                        btn.style.opacity = "1";
                        btn.style.pointerEvents = "auto";
                        btn.style.transform = "translateY(0)";
                    }
                } else if (index === getPrevIndex()) {
                    el.style.transform = `translateX(-${shiftAmount}) scale(${scaleAmount}) translateZ(-50px)`;
                    el.style.opacity = `0.6`;
                    el.style.zIndex = `20`;
                    el.style.filter = `blur(2px) brightness(0.6)`;
                    el.style.pointerEvents = "auto";

                    if (btn) {
                        btn.style.opacity = "0";
                        btn.style.pointerEvents = "none";
                        btn.style.transform = "translateY(1rem)";
                    }
                } else if (index === getNextIndex()) {
                    el.style.transform = `translateX(${shiftAmount}) scale(${scaleAmount}) translateZ(-50px)`;
                    el.style.opacity = `0.6`;
                    el.style.zIndex = `20`;
                    el.style.filter = `blur(2px) brightness(0.6)`;
                    el.style.pointerEvents = "auto";

                    if (btn) {
                        btn.style.opacity = "0";
                        btn.style.pointerEvents = "none";
                        btn.style.transform = "translateY(1rem)";
                    }
                } else {
                    el.style.transform = `translateX(0) scale(0.6) translateZ(-100px)`;
                    el.style.opacity = `0`;
                    el.style.zIndex = `10`;
                    el.style.filter = `blur(10px) brightness(0)`;
                    el.style.pointerEvents = "none";

                    if (btn) {
                        btn.style.opacity = "0";
                        btn.style.pointerEvents = "none";
                    }
                }
            });
        };

        const getPrevIndex = () => (currentIndex - 1 + total) % total;
        const getNextIndex = () => (currentIndex + 1) % total;

        let autoplayTimer: ReturnType<typeof setInterval>;

        const resetAutoplay = () => {
            clearInterval(autoplayTimer);
            autoplayTimer = setInterval(() => {
                if (!isAnimating) {
                    isAnimating = true;
                    currentIndex = getNextIndex();
                    updateCarousel();
                    setTimeout(() => (isAnimating = false), 700);
                }
            }, 5000);
        };

        const goToPrev = () => {
            if (isAnimating) return;
            isAnimating = true;
            currentIndex = getPrevIndex();
            updateCarousel();
            resetAutoplay();
            setTimeout(() => (isAnimating = false), 700);
        };

        const goToNext = () => {
            if (isAnimating) return;
            isAnimating = true;
            currentIndex = getNextIndex();
            updateCarousel();
            resetAutoplay();
            setTimeout(() => (isAnimating = false), 700);
        };

        btnPrev?.addEventListener("click", goToPrev);
        btnNext?.addEventListener("click", goToNext);

        items.forEach((item, index) => {
            item.addEventListener("click", (e) => {
                const target = e.target as HTMLElement;
                const isBtn = target.closest(".carousel-btn");

                if (index !== currentIndex && !isBtn) {
                    e.preventDefault();
                    if (isAnimating) return;
                    isAnimating = true;
                    currentIndex = index;
                    updateCarousel();
                    resetAutoplay();
                    setTimeout(() => (isAnimating = false), 700);
                }
            });
        });

        window.addEventListener("resize", () => {
            updateCarousel();
        });

        updateCarousel();
        resetAutoplay();
    });
</script>
