---
import { Image } from "astro:assets";
import { socials } from "../../data/data";
import Icons from "./Icons.astro";

const currentYear = new Date().getFullYear();
---

<footer class="bg-black-50 pt-20 pb-10 border-t border-black-200 relative overflow-hidden">
    <!-- Luces tenues de fondo (Modo Claro) -->
    <div class="absolute top-0 right-[-10%] w-[500px] h-[500px] bg-primary-200/30 rounded-full blur-[120px] pointer-events-none -z-0"></div>
    <div class="absolute bottom-[-10%] left-[-10%] w-[400px] h-[400px] bg-blue-200/30 rounded-full blur-[100px] pointer-events-none -z-0"></div>
    
    <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8 mb-16">
            
            <!-- Brand & Info -->
            <div class="lg:col-span-5 flex flex-col items-start pr-0 lg:pr-12">
                <a href="#inicio" class="flex items-center gap-4 mb-6 group">
                    <div class="relative w-14 h-14 rounded-full overflow-hidden border border-black-100 shadow-sm group-hover:border-primary-300 transition-colors">
                        <Image
                            src="/logo.webp"
                            alt="CetZz Labs"
                            width={80}
                            height={80}
                            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                        />
                    </div>
                    <span class="text-2xl font-bold text-black-900 tracking-tight">CetZz Labs</span>
                </a>
                <p class="text-black-600 text-sm md:text-base leading-relaxed mb-8">
                    Diseñamos y desarrollamos soluciones digitales premium que transforman negocios, automatizan procesos y conectan con tu audiencia a un nivel superior.
                </p>
                <a href="mailto:contacto@cetzzlabs.com" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white border border-black-200 text-primary-600 font-medium hover:bg-primary-50 hover:border-primary-200 transition-all text-sm shadow-sm hover:shadow-soft">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                    contacto@cetzzlabs.com
                </a>
            </div>

            <!-- Navegación -->
            <div class="lg:col-span-2 flex flex-col">
                <h4 class="text-black-900 font-semibold mb-6 tracking-wide">Navegación</h4>
                <div class="flex flex-col gap-3">
                    <a href="#quienes-somos" class="text-black-500 hover:text-primary-600 transition-colors text-sm w-fit flex items-center gap-2 group">
                        <span class="w-1 h-1 rounded-full bg-primary-500 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                        Quiénes somos
                    </a>
                    <a href="#servicios" class="text-black-500 hover:text-primary-600 transition-colors text-sm w-fit flex items-center gap-2 group">
                        <span class="w-1 h-1 rounded-full bg-primary-500 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                        Servicios
                    </a>
                    <a href="#proceso" class="text-black-500 hover:text-primary-600 transition-colors text-sm w-fit flex items-center gap-2 group">
                        <span class="w-1 h-1 rounded-full bg-primary-500 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                        Proceso
                    </a>
                    <a href="#portafolio" class="text-black-500 hover:text-primary-600 transition-colors text-sm w-fit flex items-center gap-2 group">
                        <span class="w-1 h-1 rounded-full bg-primary-500 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                        Portafolio
                    </a>
                </div>
            </div>

            <!-- Servicios -->
            <div class="lg:col-span-3 flex flex-col">
                <h4 class="text-black-900 font-semibold mb-6 tracking-wide">Servicios Principales</h4>
                <div class="flex flex-col gap-3 text-sm text-black-500">
                    <span class="hover:text-primary-600 transition-colors cursor-default">Página Web Única (Landing)</span>
                    <span class="hover:text-primary-600 transition-colors cursor-default">Tienda Online E-commerce</span>
                    <span class="hover:text-primary-600 transition-colors cursor-default">Estrategia Digital & Ads</span>
                    <span class="hover:text-primary-600 transition-colors cursor-default">Sistemas a Medida</span>
                </div>
            </div>

            <!-- Redes Sociales -->
            <div class="lg:col-span-2 flex flex-col">
                <h4 class="text-black-900 font-semibold mb-6 tracking-wide">Síguenos</h4>
                <div class="flex flex-wrap items-center gap-3">
                    {
                        socials.map((social) => (
                            <a
                                href={social.url}
                                target="_blank"
                                class="w-10 h-10 rounded-full bg-white border border-black-200 flex items-center justify-center text-black-500 hover:bg-primary-600 hover:text-white hover:border-primary-600 transition-all duration-300 shadow-sm hover:shadow-soft hover:-translate-y-1"
                                title={social.name}
                                aria-label={social.name}
                            >
                                <Icons name={social.name} />
                            </a>
                        ))
                    }
                </div>
            </div>
        </div>

        <!-- Línea inferior de Copyright -->
        <div class="pt-8 border-t border-black-200 flex flex-col md:flex-row justify-between items-center gap-4">
            <p class="text-black-400 text-sm">
                &copy; {currentYear} CetZz Labs. Todos los derechos reservados.
            </p>
            <div class="flex gap-6 text-sm text-black-400">
                <a href="#" class="hover:text-black-600 transition-colors">Términos y Condiciones</a>
                <a href="#" class="hover:text-black-600 transition-colors">Privacidad</a>
            </div>
        </div>
    </div>
</footer>
