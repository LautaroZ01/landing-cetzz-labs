---
import { Image } from "astro:assets";
import { socials } from "../../data/data";
import Icons from "./Icons.astro";

const currentYear = new Date().getFullYear();
---

<footer
    class="bg-[#03060c] pt-20 pb-10 border-t border-white/5 relative overflow-hidden"
>
    <!-- Luces tenues de fondo -->
    <div
        class="absolute top-0 right-[-10%] w-[500px] h-[500px] bg-cyan-900/10 rounded-full blur-[120px] pointer-events-none -z-0"
    >
    </div>
    <div
        class="absolute bottom-[-10%] left-[-10%] w-[400px] h-[400px] bg-blue-900/10 rounded-full blur-[100px] pointer-events-none -z-0"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8 mb-16"
        >
            <!-- Brand & Info (Ocupa más espacio) -->
            <div class="lg:col-span-5 flex flex-col items-start pr-0 lg:pr-12">
                <a href="#inicio" class="flex items-center gap-4 mb-6 group">
                    <div class="relative w-14 h-14">
                        <Image
                            src="/logo.webp"
                            alt="CetZz Labs"
                            width={80}
                            height={80}
                            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                        />
                    </div>
                    <span class="text-2xl font-bold text-white tracking-tight"
                        >CetZz Labs</span
                    >
                </a>
                <p
                    class="text-gray-400 text-sm md:text-base leading-relaxed mb-8"
                >
                    Diseñamos y desarrollamos soluciones digitales premium que
                    transforman negocios, automatizan procesos y conectan con tu
                    audiencia a un nivel superior.
                </p>
                <a
                    href="mailto:cetzzlabs@gmail.com"
                    class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white/5 border border-white/10 text-cyan-400 font-medium hover:bg-cyan-900/30 hover:border-cyan-500/50 transition-all text-sm"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><rect width="20" height="16" x="2" y="4" rx="2"
                        ></rect><path
                            d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
                        ></path></svg
                    >
                    cetzzlabs@gmail.com
                </a>
            </div>

            <!-- Navegación -->
            <div class="lg:col-span-2 flex flex-col">
                <h4 class="text-white font-semibold mb-6 tracking-wide">
                    Navegación
                </h4>
                <div class="flex flex-col gap-3">
                    <a
                        href="#quienes-somos"
                        class="text-gray-400 hover:text-cyan-400 transition-colors text-sm w-fit flex items-center gap-2 group"
                    >
                        <span
                            class="w-1 h-1 rounded-full bg-cyan-500 opacity-0 group-hover:opacity-100 transition-opacity"
                        ></span>
                        Quiénes somos
                    </a>
                    <a
                        href="#servicios"
                        class="text-gray-400 hover:text-cyan-400 transition-colors text-sm w-fit flex items-center gap-2 group"
                    >
                        <span
                            class="w-1 h-1 rounded-full bg-cyan-500 opacity-0 group-hover:opacity-100 transition-opacity"
                        ></span>
                        Servicios
                    </a>
                    <a
                        href="#proceso"
                        class="text-gray-400 hover:text-cyan-400 transition-colors text-sm w-fit flex items-center gap-2 group"
                    >
                        <span
                            class="w-1 h-1 rounded-full bg-cyan-500 opacity-0 group-hover:opacity-100 transition-opacity"
                        ></span>
                        Proceso
                    </a>
                    <a
                        href="#portafolio"
                        class="text-gray-400 hover:text-cyan-400 transition-colors text-sm w-fit flex items-center gap-2 group"
                    >
                        <span
                            class="w-1 h-1 rounded-full bg-cyan-500 opacity-0 group-hover:opacity-100 transition-opacity"
                        ></span>
                        Portafolio
                    </a>
                </div>
            </div>

            <!-- Servicios -->
            <div class="lg:col-span-3 flex flex-col">
                <h4 class="text-white font-semibold mb-6 tracking-wide">
                    Servicios Principales
                </h4>
                <div class="flex flex-col gap-3 text-sm text-gray-400">
                    <span
                        class="hover:text-white transition-colors cursor-default"
                        >Página Web Única (Landing)</span
                    >
                    <span
                        class="hover:text-white transition-colors cursor-default"
                        >Tienda Online E-commerce</span
                    >
                    <span
                        class="hover:text-white transition-colors cursor-default"
                        >Estrategia Digital & Ads</span
                    >
                    <span
                        class="hover:text-white transition-colors cursor-default"
                        >Sistemas a Medida</span
                    >
                </div>
            </div>

            <!-- Redes Sociales -->
            <div class="lg:col-span-2 flex flex-col">
                <h4 class="text-white font-semibold mb-6 tracking-wide">
                    Síguenos
                </h4>
                <div class="flex flex-wrap items-center gap-3">
                    {
                        socials.map((social) => (
                            <a
                                href={social.url}
                                target="_blank"
                                class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 hover:bg-cyan-600 hover:text-white hover:border-cyan-500 transition-all duration-300 shadow-sm hover:shadow-[0_0_15px_rgba(8,145,178,0.4)] hover:-translate-y-1"
                                title={social.name}
                                aria-label={social.name}
                            >
                                <Icons name={social.name} />
                            </a>
                        ))
                    }
                </div>
            </div>
        </div>

        <!-- Línea inferior de Copyright -->
        <div
            class="pt-8 border-t border-white/10 flex flex-col md:flex-row justify-center items-center gap-4"
        >
            <p class="text-gray-500 text-sm">
                &copy; {currentYear} CetZz Labs. Todos los derechos reservados.
            </p>
        </div>
    </div>
</footer>
