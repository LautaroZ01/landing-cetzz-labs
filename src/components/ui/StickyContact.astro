---
import Icons from "./Icons.astro";
import { whatsApp } from "../../data/data";
---

<div class="sticky-contact">
    <a
        href={whatsApp.url}
        target="_blank"
        title={whatsApp.name}
        aria-label={whatsApp.name}
        class="block bg-[#25D366] text-white rounded-full shadow-soft p-4 hover:bg-[#1ebd5a] hover:shadow-soft-hover transition-all duration-300 hover:-translate-y-1 active:scale-95"
    >
        <Icons name={whatsApp.name} />
    </a>
</div>
