---
import {
    Facebook,
    Instagram,
    type AstroComponent,
    Mail,
    Phone,
    MapPin, Clock, Calendar,
} from "@lucide/astro";
import TikTok from "../svg/TikTok.astro";
import WhatsApp from "../svg/social/WhatsApp.astro";

const { name } = Astro.props;

const icons: Record<string, AstroComponent> = {
    facebook: Facebook,
    instagram: Instagram,
    tiktok: TikTok,
    email: Mail,
    phone: Phone,
    address: MapPin,
    whatsapp: WhatsApp,
    clock: Clock,
    calendar: Calendar
};

const Icon = icons[name.toLowerCase()] || null;
---

{Icon ? <Icon /> : null}
