---
import EcommerceIcon from "./svg/EcommerceIcon.astro";
import CorporateIcon from "./svg/CorporateIcon.astro";
import InteractiveIcon from "./svg/InteractiveIcon.astro";
import MaintenanceIcon from "./svg/MaintenanceIcon.astro";
import SeoIcon from "./svg/SeoIcon.astro";
import LandingPageIcon from "./svg/LandingPageIcon.astro";

---

<section
    id="servicios"
    class="py-20 bg-gradient-to-tr from-black-950 to-labs from-10% relative"
>
    <div class="rocket-bg top-1/3 left-1/3"></div>

    <div class="container-labs text-center">
        <h2 class="title-secundary title-style">Nuestros Servicios</h2>

        <p class="text-lg mb-12 text-gray-400">
            Creamos páginas web modernas y funcionales adaptadas a las
            necesidades de tu negocio.
        </p>

        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 auto-rows-[minmax(280px,auto)]"
        >
            <div
                class="group relative rounded-3xl p-[1px] bg-gray-800/50 transition-colors duration-500 lg:col-span-2 lg:row-span-2"
            >
                <div class="cardInnerClass">
                    <LandingPageIcon />

                    <div class="relative z-10 mt-auto pointer-events-none">
                        <div class="flex justify-between items-start mb-8">
                        </div>

                        <h3
                            class="text-3xl font-bold text-white mb-3 drop-shadow-md"
                        >
                            Landing Pages
                        </h3>
                        <p
                            class="text-gray-400 text-lg max-w-[80%] font-medium drop-shadow-sm mx-auto"
                        >
                            Diseñadas para <span class="font-bold text-cyan-400"
                                >captar clientes</span
                            > y aumentar tus <span class="font-bold text-cyan-400"
                                >conversiones</span
                            >
                        </p>
                    </div>
                </div>
            </div>

            <div
                class="group relative rounded-3xl bg-gray-800/50 transition-colors duration-500 lg:col-span-2 lg:row-span-1"
            >
                <div class="cardInnerClass">
                    <EcommerceIcon />
                    <div class="mt-auto pointer-events-none">
                        <h3
                            class="text-3xl font-bold text-white mb-3 drop-shadow-md"
                        >
                            E-commerce
                        </h3>
                        <p
                            class="text-gray-400 text-lg max-w-[80%] font-medium drop-shadow-sm mx-auto"
                        >
                            Tiendas con <span class="font-bold text-cyan-400"
                                >pasarelas seguras</span
                            > y gestión sencilla.
                        </p>
                    </div>
                </div>
            </div>

            <div
                class="group relative rounded-3xl bg-gray-800/50 transition-colors duration-500 lg:col-span-1 lg:row-span-1"
            >
                <div class="cardInnerClass">
                    <CorporateIcon />
                    <div class="mt-auto pointer-events-none">
                        <h3
                            class="text-xl font-bold text-white mb-3 drop-shadow-md"
                        >
                            Páginas Corporativas
                        </h3>
                        <p
                            class="text-gray-400 text-lg max-w-[80%] font-medium drop-shadow-sm mx-auto"
                        >
                            Tu <span class="font-bold text-cyan-400">esencia</span> profesional.
                        </p>
                    </div>
                </div>
            </div>

            <div
                class="group relative rounded-3xl bg-gray-800/50 transition-colors duration-500 lg:col-span-1 lg:row-span-1"
            >
                <div class="cardInnerClass">
                    <InteractiveIcon />
                    <div class="mt-auto pointer-events-none">
                        <h3
                            class="text-xl font-bold text-white mb-3 drop-shadow-md"
                        >
                            Diseños interactivos
                        </h3>

                        <p
                            class="text-gray-400 text-lg max-w-[80%] font-medium drop-shadow-sm mx-auto"
                        >
                            Experiencias <span class="font-bold text-cyan-400"
                                >únicas</span
                            > y fluidas.
                        </p>
                    </div>
                </div>
            </div>

            <div
                class="group relative rounded-3xl bg-gray-800/50 transition-colors duration-500 lg:col-span-2 lg:row-span-1"
            >
                <div class="cardInnerClass">
                    <MaintenanceIcon />
                    <div class="mt-auto pointer-events-none">
                        <h3
                            class="text-xl font-bold text-white mb-3 drop-shadow-md"
                        >
                            Mantenimiento
                        </h3>

                        <p
                            class="text-gray-400 text-lg max-w-[80%] font-medium drop-shadow-sm mx-auto"
                        >
                            Actualizaciones, seguridad y <span
                                class="font-bold text-cyan-400"
                            >
                                soporte continuo
                            </span>.
                        </p>
                    </div>
                </div>
            </div>

            <div
                class="group relative rounded-3xl bg-gray-800/50 transition-colors duration-500 lg:col-span-2 lg:row-span-1"
            >
                <div class="cardInnerClass">
                    <SeoIcon />
                    <div class="mt-auto pointer-events-none">
                        <h3
                            class="text-xl font-bold text-white mb-3 drop-shadow-md"
                        >
                            SEO & Velocidad
                        </h3>

                        <p
                            class="text-gray-400 text-lg max-w-[80%] font-medium drop-shadow-sm mx-auto"
                        >
                            <span class="font-bold text-cyan-400">
                                Optimización
                            </span> para
                            <span class="font-bold text-cyan-400"> Google </span> y
                            <span class="font-bold text-cyan-400">
                                velocidad
                            </span>.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
