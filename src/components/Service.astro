---
import EcommerceIcon from "./svg/EcommerceIcon.astro";
import CorporateIcon from "./svg/CorporateIcon.astro";
import InteractiveIcon from "./svg/InteractiveIcon.astro";
import SeoIcon from "./svg/SeoIcon.astro";
import LandingPageIcon from "./svg/LandingPageIcon.astro";

import {
    MonitorSmartphone,
    ShoppingCart,
    Building2,
    Paintbrush,
    TrendingUp,
    ArrowRight,
} from "@lucide/astro";

const servicesData = [
    {
        id: "service-0",
        shortTitle: "Página Web",
        title: "Página Única",
        description:
            "Ideal para publicidad y redes sociales. Está diseñada estratégicamente para atrapar la atención al instante y conseguirte clientes rápido con un solo vistazo.",
        iconWidth: "w-[50%] md:w-[60%]",
        iconScale: "scale-125",
        iconHover: "group-hover/panel:scale-[1.35]",
    },
    {
        id: "service-1",
        shortTitle: "Tienda Online",
        title: "Tienda Online",
        description:
            "Tu negocio en internet abierto las 24 horas. Podrás exhibir todos tus productos y vender de forma completamente segura, integrando diversos métodos de pago para facilitar la compra.",
        iconWidth: "w-[45%] md:w-[55%]",
        iconScale: "scale-110",
        iconHover: "group-hover/panel:scale-[1.2]",
    },
    {
        id: "service-2",
        shortTitle: "Web Institucional",
        title: "Web Institucional",
        description:
            "La sucursal digital oficial de tu marca. Transmite máxima confianza y profesionalismo a quienes te buscan en internet, mostrando qué haces, quiénes son y por qué elegirte.",
        iconWidth: "w-[45%] md:w-[55%]",
        iconScale: "scale-110",
        iconHover: "group-hover/panel:scale-[1.2]",
    },
    {
        id: "service-3",
        shortTitle: "Diseño a Medida",
        title: "Diseño a Medida",
        description:
            "Sistemas web construidos totalmente desde cero a tu gusto. Sorprendemos a tus visitantes con interacciones y flujos únicos pensados exclusivamente para destacar tu empresa sobre el resto.",
        iconWidth: "w-[50%] md:w-[60%]",
        iconScale: "scale-125",
        iconHover: "group-hover/panel:scale-[1.35]",
    },
    {
        id: "service-4",
        shortTitle: "Primeros en Google (SEO)",
        title: "SEO y Velocidad",
        description:
            "Optimizamos a fondo la web para hacerla rapidísima y que, cuando alguien busque tu servicio en internet, logres aparecer orgánicamente en los primeros lugares de Google.",
        iconWidth: "w-[50%] md:w-[60%]",
        iconScale: "scale-125",
        iconHover: "group-hover/panel:scale-[1.35]",
    },
];
---

<section
    id="servicios"
    class="py-20 lg:py-32 bg-gradient-to-tr from-black-950 to-labs from-10% relative overflow-hidden"
>
    <div class="rocket-bg top-1/3 left-1/3 opacity-70 mix-blend-screen"></div>
    <div
        class="absolute top-[20%] right-[-10%] w-[600px] h-[600px] bg-cyan-800/10 rounded-full blur-[120px] -z-0 pointer-events-none"
    >
    </div>
    <div
        class="absolute bottom-[10%] left-[-10%] w-[500px] h-[500px] bg-blue-900/10 rounded-full blur-[100px] -z-0 pointer-events-none"
    >
    </div>

    <div class="container-labs text-center mb-16 relative z-10">
        <h2 class="title-secundary title-style">Nuestros Servicios</h2>
        <p class="text-lg text-gray-400 max-w-2xl mx-auto">
            Soluciones simples y atractivas enfocadas en lo que de verdad
            importa: hacer crecer tu negocio.
        </p>
    </div>

    <div
        class="container-labs grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-12 relative z-10 pb-10"
    >
        <div
            class="lg:col-span-5 flex flex-col gap-3 lg:gap-4 h-full"
            id="service-list"
        >
            {
                servicesData.map(({ id, shortTitle }, index) => (
                    <button
                        class={`service-btn group ${index === 0 ? "active" : ""} text-left w-full h-full relative rounded-2xl p-4 md:p-5 bg-gray-800/30 border border-transparent hover:border-gray-700/80 hover:bg-gray-800/60 transition-all duration-300 flex-1 flex items-center`}
                        data-target={id}
                    >
                        <div class="absolute left-0 top-0 h-full w-1 bg-cyan-500 rounded-l-2xl opacity-0 group-[.active]:opacity-100 transition-opacity" />

                        <div class="flex items-center justify-between gap-4 relative z-10 pointer-events-none w-full pl-2">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 flex-shrink-0 flex items-center justify-center rounded-xl bg-gray-900 border border-gray-700/50 group-[.active]:ring-2 group-[.active]:ring-cyan-500 group-[.active]:border-transparent transition-all group-hover:border-cyan-500/50 shadow-sm group-[.active]:shadow-cyan-500/20">
                                    {id === "service-0" && (
                                        <MonitorSmartphone class="w-6 h-6 text-gray-400 group-[.active]:text-cyan-400 transition-colors" />
                                    )}
                                    {id === "service-1" && (
                                        <ShoppingCart class="w-6 h-6 text-gray-400 group-[.active]:text-cyan-400 transition-colors" />
                                    )}
                                    {id === "service-2" && (
                                        <Building2 class="w-6 h-6 text-gray-400 group-[.active]:text-cyan-400 transition-colors" />
                                    )}
                                    {id === "service-3" && (
                                        <Paintbrush class="w-6 h-6 text-gray-400 group-[.active]:text-cyan-400 transition-colors" />
                                    )}
                                    {id === "service-4" && (
                                        <TrendingUp class="w-6 h-6 text-gray-400 group-[.active]:text-cyan-400 transition-colors" />
                                    )}
                                </div>
                                <h3 class="text-lg md:text-xl font-bold text-gray-300 group-[.active]:text-white transition-colors">
                                    {shortTitle}
                                </h3>
                            </div>
                            <div class="text-gray-600 group-[.active]:text-cyan-400 transition-colors opacity-0 group-[.active]:opacity-100 group-hover:opacity-100 hidden sm:block">
                                <ArrowRight class="w-5 h-5" />
                            </div>
                        </div>
                    </button>
                ))
            }
        </div>

        <div
            class="lg:col-span-7 backdrop-blur-md bg-gray-900/60 border border-gray-700/50 rounded-3xl overflow-hidden relative lg:sticky lg:top-32 min-h-[450px] h-full shadow-[0_0_50px_-12px_rgba(0,0,0,0.5)] flex flex-col mt-4 lg:mt-0 group/panel"
        >
            <div
                class="absolute inset-0 bg-gradient-to-tr from-cyan-900/10 to-transparent pointer-events-none z-0"
            >
            </div>

            {
                servicesData.map(
                    (
                        {
                            id,
                            title,
                            description,
                            iconWidth,
                            iconScale,
                            iconHover,
                        },
                        index,
                    ) => (
                        <div
                            id={id}
                            class={`service-detail ${index === 0 ? "relative opacity-100 translate-y-0 z-10" : "absolute top-0 left-0 opacity-0 translate-y-8 pointer-events-none -z-10"} w-full h-full p-8 md:p-12 flex flex-col justify-center transition-all duration-500`}
                        >
                            <div class="absolute inset-0 opacity-10 pointer-events-none -z-10 bg-gradient-to-br from-cyan-500/20 to-transparent" />

                            <div class="relative z-20">
                                <h3 class="text-3xl md:text-5xl font-bold text-white mb-6 drop-shadow-md pr-16 md:pr-0">
                                    {title}
                                </h3>
                                <p class="text-lg md:text-xl text-gray-300 mb-10 leading-relaxed font-medium">
                                    {description}
                                </p>
                            </div>

                            <div class="mt-auto relative z-20">
                                <a
                                    href="#contacto"
                                    class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-cyan-600 hover:bg-cyan-500 text-white font-bold rounded-full transition-all hover:scale-105 active:scale-95 shadow-[0_0_20px_rgba(8,145,178,0.3)] hover:shadow-[0_0_30px_rgba(8,145,178,0.5)]"
                                >
                                    Me interesa
                                    <ArrowRight class="w-5 h-5" />
                                </a>
                            </div>

                            <div
                                class={`absolute right-0 bottom-0 ${iconWidth} opacity-[0.25] md:opacity-30 pointer-events-none ${iconScale} translate-x-12 translate-y-12 transition-transform duration-700 ease-out ${iconHover} group-hover/panel:-translate-y-4`}
                            >
                                {id === "service-0" && <LandingPageIcon />}
                                {id === "service-1" && <EcommerceIcon />}
                                {id === "service-2" && <CorporateIcon />}
                                {id === "service-3" && <InteractiveIcon />}
                                {id === "service-4" && <SeoIcon />}
                            </div>
                        </div>
                    ),
                )
            }
        </div>
    </div>
</section>

<style>
    .service-btn.active {
        background-color: rgba(31, 41, 55, 0.8); /* bg-gray-800/80 */
        border-color: rgba(55, 65, 81, 1); /* border-gray-700 */
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const buttons = document.querySelectorAll(".service-btn");
        const details = document.querySelectorAll(".service-detail");
        let currentIndex = 0;
        let intervalId: ReturnType<typeof setInterval>;

        const activateSlide = (index: number) => {
            // Quitar activo de todos los botones
            buttons.forEach((b) => b.classList.remove("active"));

            // Ocultar todos los detalles (clases para animar)
            details.forEach((d) => {
                // Pasar a estado oculto
                d.classList.remove("opacity-100", "translate-y-0", "z-10");
                d.classList.add(
                    "opacity-0",
                    "translate-y-8",
                    "pointer-events-none",
                    "-z-10",
                );

                // Asegurar que sean position: absolute para que no ocupen el flujo
                if (d.classList.contains("relative")) {
                    d.classList.replace("relative", "absolute");
                } else {
                    d.classList.add("absolute");
                }
            });

            // Activar el clickeado/actual
            const btn = buttons[index];
            if (btn) {
                btn.classList.add("active");
                const targetId = btn.getAttribute("data-target");
                if (targetId) {
                    const targetDetail = document.getElementById(targetId);
                    if (targetDetail) {
                        // Pasar a estado visible
                        targetDetail.classList.remove(
                            "opacity-0",
                            "translate-y-8",
                            "pointer-events-none",
                            "-z-10",
                            "absolute",
                        );
                        targetDetail.classList.add(
                            "opacity-100",
                            "translate-y-0",
                            "z-10",
                            "relative",
                        );
                    }
                }
            }
        };

        const startInterval = () => {
            intervalId = setInterval(() => {
                currentIndex = (currentIndex + 1) % buttons.length;
                activateSlide(currentIndex);
            }, 6000); // 6 segundos por tab
        };

        const resetInterval = () => {
            clearInterval(intervalId);
            startInterval();
        };

        // Eventos manuales (Clic)
        buttons.forEach((btn, index) => {
            btn.addEventListener("click", () => {
                currentIndex = index;
                activateSlide(currentIndex);
                resetInterval(); // Detener el auto-play un rato de ese click
            });
        });

        // Iniciar el ciclo automático al cargar la página
        startInterval();
    });
</script>
