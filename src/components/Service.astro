---
import EcommerceIcon from "./svg/EcommerceIcon.astro";
import InteractiveIcon from "./svg/InteractiveIcon.astro";
import SeoIcon from "./svg/SeoIcon.astro";
import LandingPageIcon from "./svg/LandingPageIcon.astro";
import { ArrowRight } from "@lucide/astro";

const servicesData = [
    {
        id: "service-0",
        title: "Página Web Única (Landing)",
        description:
            "Ideal para publicidad y redes sociales. Está diseñada estratégicamente para atrapar la atención al instante y conseguirte clientes rápido con un solo vistazo.",
        glowColor: "bg-cyan-500",
        formValue: "Página web",
    },
    {
        id: "service-1",
        title: "Tienda Online",
        description:
            "Tu negocio en internet abierto las 24 horas. Podrás exhibir todos tus productos y vender de forma completamente segura, integrando diversos métodos de pago para facilitar la compra.",
        glowColor: "bg-indigo-500",
        formValue: "E-commerce",
    },
    {
        id: "service-2",
        title: "Estrategia y Ads",
        description:
            "Estrategia integral, creación de contenido, optimización de alcance y campañas en Meta Ads para potenciar al máximo tus conversiones.",
        glowColor: "bg-blue-500",
        formValue: "Marketing",
    },
    {
        id: "service-3",
        title: "Diseño a Medida",
        description:
            "Sistemas web construidos totalmente desde cero a tu gusto. Sorprendemos a tus visitantes con interacciones y flujos únicos pensados exclusivamente para destacar tu empresa sobre el resto.",
        glowColor: "bg-purple-500",
        formValue: "Sistema a Medida",
    },
];
---

<section
    id="servicios"
    class="pt-20 lg:pt-32 bg-black-50 relative overflow-x-clip"
>
    <div
        class="absolute top-[20%] right-[-10%] w-[600px] h-[600px] bg-primary-100/40 rounded-full blur-[120px] -z-0 pointer-events-none"
    >
    </div>
    <div
        class="absolute bottom-[10%] left-[-10%] w-[500px] h-[500px] bg-blue-100/40 rounded-full blur-[100px] -z-0 pointer-events-none"
    >
    </div>

    <div class="container-labs text-center mb-16">
        <span class="text-primary-500 font-bold tracking-widest uppercase text-sm mb-4 block">Lo que hacemos</span>
        <h2 class="section-title text-center">Nuestros <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-500 to-blue-600">Servicios</span></h2>
        <p class="section-subtitle mx-auto text-center">Soluciones digitales diseñadas para impulsar tu negocio al siguiente nivel.</p>
    </div>

    <div
        class="container-labs flex flex-col gap-6 lg:gap-8 relative z-10 pb-12"
    >
        {
            servicesData.map(
                ({ id, title, description, glowColor, formValue }, index) => (
                    <div
                        id={id}
                        class="sticky flex flex-col md:flex-row w-full rounded-[2.5rem] overflow-hidden shadow-[0_-10px_40px_rgba(0,0,0,0.05)] transition-transform duration-500 ease-in-out border border-black-100 backdrop-blur-2xl bg-white/90"
                        style={`top: calc(12vh + ${index * 35}px); min-height: 480px; z-index: ${10 + index};`}
                    >
                        <div
                            class={`absolute top-[-20%] right-[-10%] w-[450px] h-[450px] ${glowColor} rounded-full blur-[120px] opacity-10 pointer-events-none -z-10`}
                        />
                        <div
                            class={`absolute bottom-[-20%] left-[-10%] w-[350px] h-[350px] ${glowColor} rounded-full blur-[100px] opacity-10 pointer-events-none -z-10`}
                        />

                        <div class="absolute inset-0 bg-gradient-to-br from-white/60 to-white/10 pointer-events-none z-0" />

                        <div class="flex flex-col justify-between p-10 md:p-14 lg:p-16 w-full md:w-1/2 relative z-20">
                            <h3 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-black-900 mb-8 tracking-tight drop-shadow-sm pr-4">
                                {title}
                            </h3>

                            <div class="mt-auto">
                                <p class="text-lg md:text-xl text-black-600 mb-10 leading-relaxed font-medium">
                                    {description}
                                </p>

                                <a
                                    href="#contacto"
                                    data-service={formValue}
                                    class="service-btn inline-flex items-center justify-center gap-2 px-8 py-4 bg-primary-50 text-primary-600 font-bold rounded-xl transition-all duration-300 hover:bg-primary-600 hover:text-white hover:scale-105 active:scale-95 shadow-sm hover:shadow-soft border border-primary-100 hover:border-primary-500"
                                >
                                    Me interesa
                                    <ArrowRight class="w-5 h-5" />
                                </a>
                            </div>
                        </div>

                        <div class="w-full md:w-1/2 relative min-h-[300px] md:min-h-full flex items-center justify-center overflow-visible z-20 p-8 md:p-12">
                            <div class="w-full max-w-[500px] scale-125 md:scale-[1.4] origin-center -translate-y-48 md:-translate-y-40 drop-shadow-[0_20px_40px_rgba(0,0,0,0.1)] transform transition-transform duration-700 hover:scale-[1.35] hover:md:scale-[1.5]">
                                {id === "service-0" && <LandingPageIcon />}
                                {id === "service-1" && <EcommerceIcon />}
                                {id === "service-2" && <SeoIcon />}
                                {id === "service-3" && <InteractiveIcon />}
                            </div>
                        </div>
                    </div>
                ),
            )
        }
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const serviceBtns = document.querySelectorAll(".service-btn");
        serviceBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                const serviceValue = btn.getAttribute("data-service");
                const selectElement = document.getElementById(
                    "servicio",
                ) as HTMLSelectElement;
                if (selectElement && serviceValue) {
                    selectElement.value = serviceValue;
                }
            });
        });
    });
</script>
