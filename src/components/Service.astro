---
import EcommerceIcon from "./svg/EcommerceIcon.astro";
import InteractiveIcon from "./svg/InteractiveIcon.astro";
import SeoIcon from "./svg/SeoIcon.astro";
import LandingPageIcon from "./svg/LandingPageIcon.astro";
import { ArrowRight } from "@lucide/astro";

const servicesData = [
    {
        id: "service-0",
        title: "Página Web Única (Landing)",
        description:
            "Ideal para publicidad y redes sociales. Está diseñada estratégicamente para atrapar la atención al instante y conseguirte clientes rápido con un solo vistazo.",
        glowColor: "bg-cyan-500",
    },
    {
        id: "service-1",
        title: "Tienda Online",
        description:
            "Tu negocio en internet abierto las 24 horas. Podrás exhibir todos tus productos y vender de forma completamente segura, integrando diversos métodos de pago para facilitar la compra.",
        glowColor: "bg-indigo-500",
    },
    {
        id: "service-2",
        title: "Estrategia y Ads",
        description:
            "Estrategia integral, creación de contenido, optimización de alcance y campañas en Meta Ads para potenciar al máximo tus conversiones.",
        glowColor: "bg-blue-500",
    },
    {
        id: "service-3",
        title: "Diseño a Medida",
        description:
            "Sistemas web construidos totalmente desde cero a tu gusto. Sorprendemos a tus visitantes con interacciones y flujos únicos pensados exclusivamente para destacar tu empresa sobre el resto.",
        glowColor: "bg-purple-500",
    },
];
---

<section
    id="servicios"
    class="py-20 lg:py-32 bg-gradient-to-tr from-black-950 to-labs from-10% relative overflow-x-clip"
>
    <div class="rocket-bg top-1/3 left-1/3 opacity-70 mix-blend-screen"></div>
    <div
        class="absolute top-[20%] right-[-10%] w-[600px] h-[600px] bg-cyan-800/10 rounded-full blur-[120px] -z-0 pointer-events-none"
    >
    </div>
    <div
        class="absolute bottom-[10%] left-[-10%] w-[500px] h-[500px] bg-blue-900/10 rounded-full blur-[100px] -z-0 pointer-events-none"
    >
    </div>

    <div class="container-labs text-center mb-16 relative z-10">
        <h2 class="title-secundary title-style">Nuestros Servicios</h2>
        <p class="text-lg text-gray-400 max-w-2xl mx-auto">
            Soluciones simples y atractivas enfocadas en lo que de verdad
            importa: hacer crecer tu negocio.
        </p>
    </div>

    <div
        class="container-labs flex flex-col gap-6 lg:gap-8 relative z-10 pb-40"
    >
        {
            servicesData.map(({ id, title, description, glowColor }, index) => (
                <div
                    id={id}
                    class="sticky flex flex-col md:flex-row w-full rounded-[2.5rem] overflow-hidden shadow-[0_-15px_40px_rgba(0,0,0,0.5)] transition-transform duration-500 ease-in-out border border-gray-700/50 backdrop-blur-2xl bg-[#080d17]/80"
                    style={`top: calc(12vh + ${index * 35}px); min-height: 480px; z-index: ${10 + index};`}
                >
                    <div
                        class={`absolute top-[-20%] right-[-10%] w-[450px] h-[450px] ${glowColor} rounded-full blur-[120px] opacity-30 pointer-events-none -z-10`}
                    />
                    <div
                        class={`absolute bottom-[-20%] left-[-10%] w-[350px] h-[350px] ${glowColor} rounded-full blur-[100px] opacity-20 pointer-events-none -z-10`}
                    />

                    <div class="absolute inset-0 bg-gradient-to-br from-white/5 to-transparent pointer-events-none z-0" />

                    <div class="flex flex-col justify-between p-10 md:p-14 lg:p-16 w-full md:w-1/2 relative z-20">
                        <h3 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-8 tracking-tight drop-shadow-md pr-4">
                            {title}
                        </h3>

                        <div class="mt-auto">
                            <p class="text-lg md:text-xl text-gray-300/90 mb-10 leading-relaxed font-medium">
                                {description}
                            </p>

                            <a
                                href="#contacto"
                                class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/5 hover:bg-cyan-600 hover:text-white text-gray-200 font-bold rounded-full transition-all hover:scale-105 active:scale-95 shadow-[0_0_20px_rgba(0,0,0,0.1)] border border-white/10 backdrop-blur-sm"
                            >
                                Me interesa
                                <ArrowRight class="w-5 h-5" />
                            </a>
                        </div>
                    </div>

                    <div class="w-full md:w-1/2 relative min-h-[300px] md:min-h-full flex items-center justify-center overflow-visible z-20 p-8 md:p-12">
                        <div class="w-full max-w-[500px] scale-125 md:scale-[1.4] origin-center -translate-y-48 md:-translate-y-40 drop-shadow-[0_20px_50px_rgba(0,0,0,0.5)] transform transition-transform duration-700 hover:scale-[1.35] hover:md:scale-[1.5]">
                            {id === "service-0" && <LandingPageIcon />}
                            {id === "service-1" && <EcommerceIcon />}
                            {id === "service-2" && <SeoIcon />}
                            {id === "service-3" && <InteractiveIcon />}
                        </div>
                    </div>
                </div>
            ))
        }
    </div>
</section>
