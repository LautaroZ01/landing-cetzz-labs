---

---

<section
    id="quienes-somos"
    class="pb-20 pt-10 lg:pt-20 bg-gradient-to-br from-black-950 to-labs from-10% relative overflow-hidden"
>
    <div
        class="max-w-5xl mx-auto px-6 grid md:grid-cols-2 gap-12 lg:gap-20 items-center relative z-10"
    >
        <div
            class="about-video relative w-full md:aspect-[6/5] flex justify-center items-center opacity-0"
        >
            <video
                src="/hero-video.mp4"
                autoplay
                loop
                muted
                playsinline
                class="w-full h-full object-cover mask-radial-at-center mask-radial-from-5% mask-radial-to-70% scale-[1.3] lg:scale-[1.5]"
            ></video>
        </div>

        <div class="flex flex-col gap-8 items-start">
            <h2
                class="about-text text-4xl md:text-5xl lg:text-6xl font-extrabold title-style leading-tight opacity-0"
            >
                Quiénes somos
            </h2>

            <div
                class="about-text flex flex-col gap-4 text-lg text-gray-300 leading-relaxed font-light opacity-0"
            >
                <p>
                    Somos un equipo apasionado por la <strong
                        class="text-white font-semibold"
                        >tecnología y el diseño</strong
                    >, especializados en crear páginas web modernas, rápidas y
                    funcionales que impulsan el crecimiento de empresas y
                    emprendedores.
                </p>
                <p>
                    Combinamos estética premium, innovación sostenible y
                    resultados medibles para desarrollar productos que destaquen
                    y conecten realmente con tu audiencia.
                </p>
            </div>

            <div
                class="about-text grid grid-cols-2 gap-8 w-full py-6 mt-2 border-y border-white/10 relative opacity-0"
            >
                <div
                    class="absolute inset-0 bg-gradient-to-r from-labs/5 to-transparent -z-10"
                >
                </div>
                <div class="flex flex-col gap-1 pl-4 border-labs">
                    <span
                        class="text-4xl lg:text-5xl font-black text-white tracking-tighter flex items-center"
                        ><span class="text-labs">+</span><span class="counter-1">0</span></span
                    >
                    <span class="text-gray-400 text-sm md:text-base font-medium"
                        >Proyectos Exitosos</span
                    >
                </div>
                <div class="flex flex-col gap-1 pl-4 border-labs/50">
                    <span
                        class="text-4xl lg:text-5xl font-black text-white tracking-tighter flex items-center"
                        ><span class="counter-2">0</span><span class="text-labs">%</span></span
                    >
                    <span class="text-gray-400 text-sm md:text-base font-medium"
                        >Enfoque a Medida</span
                    >
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        const section = document.getElementById("quienes-somos");

        if (section) {
            // Animar el contenedor del video (Fade in, Slide from left y Blur dissolve)
            gsap.fromTo(
                ".about-video",
                { opacity: 0, x: -60, filter: "blur(15px)" },
                {
                    opacity: 1,
                    x: 0,
                    filter: "blur(0px)",
                    duration: 1.5,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: section,
                        start: "top 75%",
                    },
                }
            );

            // Animar los textos de forma escalonada (Slide up)
            gsap.fromTo(
                ".about-text",
                { opacity: 0, y: 40 },
                {
                    opacity: 1,
                    y: 0,
                    duration: 1.2,
                    stagger: 0.2,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: section,
                        start: "top 75%",
                    },
                }
            );

            // Animación de contadores numéricos (solo números)
            const countElements = [
                { selector: ".counter-1", endValue: 10 },
                { selector: ".counter-2", endValue: 100 }
            ];

            countElements.forEach((item) => {
                const el = document.querySelector(item.selector);
                if (el) {
                    gsap.to(el, {
                        innerHTML: item.endValue,
                        duration: 2.5,
                        snap: { innerHTML: 1 }, // Esto fuerza a que sean números enteros
                        ease: "power2.out",
                        scrollTrigger: {
                            trigger: section,
                            start: "top 60%",
                        }
                    });
                }
            });
        }
    });
</script>
