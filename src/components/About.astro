---

---

<section
    id="quienes-somos"
    class="py-20 lg:py-32 bg-primary-100/90 relative overflow-hidden border-t border-primary-100"
>
    <div
        class="max-w-7xl mx-auto px-6 grid lg:grid-cols-[1.1fr_1fr] gap-12 lg:gap-16 items-center relative z-10"
    >
        <div
            class="about-video relative w-full aspect-square md:aspect-[4/3] flex justify-center items-center opacity-0 lg:-ml-6"
        >
            <div
                class="relative w-full h-full rounded-[2rem] lg:rounded-[3rem] overflow-hidden bg-primary-950 shadow-2xl shadow-primary-900/10 ring-1 ring-black-100 flex items-center justify-center p-1 lg:p-2"
            >
                <video
                    autoplay
                    loop
                    muted
                    playsinline
                    class="w-full h-full object-cover rounded-[1.8rem] lg:rounded-[2.8rem] scale-[1.01]"
                >
                    <source src="/hero-video.mp4" type="video/mp4" />
                </video>
                <div
                    class="absolute inset-0 rounded-[2rem] lg:rounded-[3rem] ring-1 ring-inset ring-white/10 pointer-events-none"
                >
                </div>
                <div
                    class="absolute inset-0 bg-gradient-to-t from-primary-950/40 via-transparent to-transparent pointer-events-none rounded-[2rem] lg:rounded-[3rem]"
                >
                </div>
            </div>
        </div>

        <div class="flex flex-col gap-8 items-start">
            <h2 class="about-text section-title opacity-0 text-left">
                Quiénes <span
                    class="text-transparent bg-clip-text bg-gradient-to-r from-primary-500 to-blue-600"
                    >somos</span
                >
            </h2>

            <div
                class="about-text flex flex-col gap-4 text-lg text-black-600 leading-relaxed font-normal opacity-0"
            >
                <p>
                    Somos un equipo apasionado por la <strong
                        class="text-black-900 font-bold"
                        >tecnología y el diseño</strong
                    >, especializados en crear páginas web modernas, rápidas y
                    funcionales que impulsan el crecimiento de empresas y
                    emprendedores.
                </p>
                <p>
                    Combinamos estética premium, innovación sostenible y
                    resultados medibles para desarrollar productos que destaquen
                    y conecten realmente con tu audiencia.
                </p>
            </div>

            <!-- Contadores Originales Restaurados -->
            <div
                class="about-text grid grid-cols-2 gap-4 sm:gap-6 w-full pt-8 mt-2 border-t border-primary-200 relative opacity-0"
            >
                <div
                    class="flex flex-col gap-1 pl-4 border-l-[3px] border-primary-500 bg-white/50 p-4 rounded-r-2xl"
                >
                    <span
                        class="text-4xl lg:text-5xl font-black text-black-900 tracking-tighter flex items-center"
                    >
                        <span class="text-primary-500">+</span><span
                            class="counter-about-1">0</span
                        >
                    </span>
                    <span
                        class="text-black-700 text-xs sm:text-sm font-extrabold uppercase tracking-wide"
                        >Proyectos Activos</span
                    >
                </div>
                <div
                    class="flex flex-col gap-1 pl-4 border-l-[3px] border-blue-500 bg-white/50 p-4 rounded-r-2xl"
                >
                    <span
                        class="text-4xl lg:text-5xl font-black text-black-900 tracking-tighter flex items-center"
                    >
                        <span class="counter-about-2">0</span><span
                            class="text-blue-500">%</span
                        >
                    </span>
                    <span
                        class="text-black-700 text-xs sm:text-sm font-extrabold uppercase tracking-wide"
                        >Enfoque a Medida</span
                    >
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        const section = document.getElementById("quienes-somos");

        if (section) {
            // Animar el contenedor del video
            gsap.fromTo(
                ".about-video",
                { opacity: 0, x: -60, filter: "blur(15px)" },
                {
                    opacity: 1,
                    x: 0,
                    filter: "blur(0px)",
                    duration: 1.5,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: section,
                        start: "top 75%",
                    },
                },
            );

            // Animar los textos de forma escalonada
            gsap.fromTo(
                ".about-text",
                { opacity: 0, y: 40 },
                {
                    opacity: 1,
                    y: 0,
                    duration: 1.2,
                    stagger: 0.2,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: section,
                        start: "top 75%",
                    },
                },
            );

            // Animación de contadores de About
            const aboutCounters = [
                { selector: ".counter-about-1", endValue: 40 },
                { selector: ".counter-about-2", endValue: 100 },
            ];

            aboutCounters.forEach((item) => {
                const el = document.querySelector(item.selector);
                if (el) {
                    gsap.to(el, {
                        innerHTML: item.endValue,
                        duration: 2.5,
                        snap: { innerHTML: 1 },
                        ease: "power2.out",
                        scrollTrigger: {
                            trigger: section,
                            start: "top 60%",
                        },
                    });
                }
            });
        }
    });
</script>
