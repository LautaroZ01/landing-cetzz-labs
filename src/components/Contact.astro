---
import Icons from "./ui/Icons.astro";
---

<section
    id="contacto"
    class="py-24 sm:py-32 bg-white text-black-600 relative overflow-hidden"
>
    <div class="max-w-6xl mx-auto px-6 relative z-10">
        <div
            class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-12 items-stretch"
        >
            {/* --- COLUMNA IZQUIERDA: Textos e Información --- */}
            <div class="flex flex-col gap-8">
                <div class="mb-10 text-center lg:text-left">
                    <span class="text-primary-500 font-bold tracking-widest uppercase text-sm mb-4 block">Comencemos</span>
                    <h2 class="section-title text-center lg:text-left">
                        Hablemos de tu <br class="hidden lg:block" />
                        <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-500 to-blue-600">próximo proyecto</span>
                    </h2>
                    <p class="section-subtitle text-center lg:text-left mx-auto lg:mx-0">
                        Completá el formulario o escribinos directo por WhatsApp. Estamos listos para ayudarte a escalar tu negocio.
                    </p>
                </div>

                <div class="flex flex-col gap-4 mt-2">
                    {/* Tarjeta 1: Ubicación */}
                    <div
                        class="flex items-center gap-4 p-5 rounded-2xl bg-white border border-black-100 shadow-sm hover:shadow-md transition-shadow"
                    >
                        <div
                            class="bg-primary-50 p-3 rounded-full text-primary-600"
                        >
                            <Icons name="address" />
                        </div>
                        <div>
                            <h3 class="text-black-900 font-bold text-[17px]">
                                Estamos en Salta capital
                            </h3>
                            <p class="text-black-600 text-sm mt-0.5">
                                Trabajamos con clientes de toda Argentina de
                                forma 100% online.
                            </p>
                        </div>
                    </div>

                    {/* Tarjeta 2: Días */}
                    <div
                        class="flex items-center gap-4 p-5 rounded-2xl bg-white border border-black-100 shadow-sm hover:shadow-md transition-shadow"
                    >
                        <div
                            class="bg-primary-50 p-3 rounded-full text-primary-600"
                        >
                            <Icons name="calendar" />
                        </div>
                        <div>
                            <h3 class="text-black-900 font-bold text-[17px]">
                                Días de atención
                            </h3>
                            <p class="text-black-600 text-sm mt-0.5">
                                Lunes a Viernes · Sábados con turno previo
                            </p>
                        </div>
                    </div>

                    {/* Tarjeta 3: Horarios */}
                    <div
                        class="flex items-center gap-4 p-5 rounded-2xl bg-white border border-black-100 shadow-sm hover:shadow-md transition-shadow"
                    >
                        <div
                            class="bg-primary-50 p-3 rounded-full text-primary-600"
                        >
                            <Icons name="clock" />
                        </div>
                        <div>
                            <h3 class="text-black-900 font-bold text-[17px]">
                                Horarios
                            </h3>
                            <p class="text-black-600 text-sm mt-0.5">
                                9:00 a 21:00 hs (ART)
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            {/* --- COLUMNA DERECHA: Formulario --- */}
            <div class="relative w-full">
                {/* Brillo de fondo sutil detrás del formulario */}
                <div
                    class="absolute inset-0 bg-gradient-to-tr from-primary-200/40 via-transparent to-[#25D366]/20 rounded-3xl blur-2xl -z-10"
                >
                </div>

                <div
                    class="relative bg-white/80 backdrop-blur-xl border border-black-100 rounded-[2rem] p-8 sm:p-10 shadow-xl"
                >
                    <div class="flex items-center gap-2 mb-3">
                        <div class="w-2 h-2 rounded-full bg-[#25D366]"></div>
                        <span
                            class="text-[#25D366] text-xs font-bold uppercase tracking-wide"
                        >
                            Asesoramiento gratuito
                        </span>
                    </div>

                    <h3 class="text-2xl font-bold text-black-900 mb-8">
                        Contanos sobre tu proyecto
                    </h3>

                    {/* Formulario */}
                    <form id="whatsapp-form" class="flex flex-col gap-5">
                        {/* Input Nombre */}
                        <div class="flex flex-col gap-1.5 w-full">
                            <label
                                for="nombre"
                                class="text-sm font-semibold text-black-700 ml-1"
                                >Nombre</label
                            >
                            <input
                                type="text"
                                id="nombre"
                                placeholder="Tu nombre"
                                class="bg-black-50 border border-black-100 text-black-900 text-sm rounded-xl px-4 py-3.5 focus:outline-none focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-all w-full placeholder:text-black-400"
                                required
                            />
                        </div>

                        {/* Select Necesidad */}
                        <div class="flex flex-col gap-1.5 relative">
                            <label
                                for="servicio"
                                class="text-sm font-semibold text-black-700 ml-1"
                                >¿Qué necesitás?</label
                            >
                            <select
                                id="servicio"
                                class="bg-black-50 border border-black-100 text-black-900 text-sm rounded-xl px-4 py-3.5 focus:outline-none focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-all w-full appearance-none cursor-pointer"
                            >
                                <option value="Página web">Página web</option>
                                <option value="E-commerce">E-commerce</option>
                                <option value="Rediseño">Rediseño web</option>
                                <option value="Marketing"
                                    >Campañas/Marketing</option
                                >
                                <option value="Sistema a Medida"
                                    >Sistema a Medida</option
                                >
                                <option value="Otro">Otro</option>
                            </select>
                            {/* Flecha personalizada para el select */}
                            <div
                                class="pointer-events-none absolute right-4 top-[38px] text-black-500"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><path d="m6 9 6 6 6-6"></path></svg
                                >
                            </div>
                        </div>

                        {/* Textarea Mensaje */}
                        <div class="flex flex-col gap-1.5">
                            <label
                                for="mensaje"
                                class="text-sm font-semibold text-black-700 ml-1"
                                >Mensaje (opcional)</label
                            >
                            <textarea
                                id="mensaje"
                                rows="3"
                                placeholder="Contanos brevemente sobre tu negocio..."
                                class="bg-black-50 border border-black-100 text-black-900 text-sm rounded-xl px-4 py-3.5 focus:outline-none focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 transition-all w-full resize-none placeholder:text-black-400"
                            ></textarea>
                        </div>

                        {/* Botón Enviar */}
                        <button
                            type="submit"
                            class="mt-3 w-full bg-[#25D366] hover:bg-[#128C7E] text-white font-bold rounded-xl px-4 py-4 flex cursor-pointer items-center justify-center gap-2 transition-colors duration-300 shadow-md hover:shadow-lg"
                        >
                            <Icons name="whatsapp" />
                            Enviar por WhatsApp
                        </button>

                        <p
                            class="text-center text-xs text-black-500 mt-2 font-medium"
                        >
                            Te respondemos en horario de atención. Sin spam.
                            Cero costo.
                        </p>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    // Lógica opcional del lado del cliente para construir el mensaje de WhatsApp
    const form = document.getElementById("whatsapp-form");

    if (form) {
        form.addEventListener("submit", (e) => {
            e.preventDefault();

            const nombre = (
                document.getElementById("nombre") as HTMLInputElement
            ).value;
            const servicio = (
                document.getElementById("servicio") as HTMLSelectElement
            ).value;
            const mensaje = (
                document.getElementById("mensaje") as HTMLTextAreaElement
            ).value;

            // Reemplaza esto con tu número de teléfono real con código de área (sin el +)
            const numeroDestino = "5493875636478";

            let textoWhatsApp = `Hola! Soy ${nombre}. Me interesa el servicio de ${servicio}.`;
            if (mensaje) {
                textoWhatsApp += `\n\nTe comento un poco: ${mensaje}`;
            }
            const url = `https://wa.me/${numeroDestino}?text=${encodeURIComponent(textoWhatsApp)}`;

            window.open(url, "_blank");
        });
    }
</script>
